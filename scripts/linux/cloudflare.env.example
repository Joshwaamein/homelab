# Copy to /etc/ddns/cloudflare.env and chmod 600 root:root.
# Never commit the populated file to git.

# Scoped Cloudflare API token (DNS:Edit on the target zone).
# https://dash.cloudflare.com/profile/api-tokens
API_TOKEN=<your-cloudflare-api-token>

# 32-hex zone ID (Overview tab of the zone in the Cloudflare dashboard).
ZONE_ID=<your-cloudflare-zone-id>

# Fully-qualified A record this host should keep pointed at its public IP.
RECORD_NAME=host1.example.com
